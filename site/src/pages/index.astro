---
import '../styles/global.css';
import BaseLayout from '@mcptoolshop/site-theme/components/BaseLayout.astro';
import Hero from '@mcptoolshop/site-theme/components/Hero.astro';
import Section from '@mcptoolshop/site-theme/components/Section.astro';
import FeatureGrid from '@mcptoolshop/site-theme/components/FeatureGrid.astro';
import DataTable from '@mcptoolshop/site-theme/components/DataTable.astro';
import CodeCardGrid from '@mcptoolshop/site-theme/components/CodeCardGrid.astro';
import ApiList from '@mcptoolshop/site-theme/components/ApiList.astro';
import { config } from '../site-config';

// F-004 fix: nav anchors must be absolute (base-prefixed) so they navigate
// from non-homepage routes (e.g. handbook pages) back to the homepage section,
// instead of resolving to `/sovereignty/handbook/some-page/#features` which
// scrolls nowhere because the handbook layout has no element with that ID.
// `import.meta.env.BASE_URL` is the configured Astro `base` ('/sovereignty');
// normalize trailing slash so we always emit `/sovereignty/#features`.
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

// F-FE-001 (Wave 9): "What's new in v2.0.0" highlights surfaced as a
// landing-page section. Modeled here in index.astro (rather than as an entry
// in config.sections) because it carries inline links — site-theme's
// FeatureGrid renders desc as plain text, so anchor markup would be escaped.
// Keeping it local avoids touching site-theme's SectionConfig union and
// stays surgical to this release.
const whatsNewFeatures = [
  {
    title: 'Hardened proof format',
    desc: 'The round-proof envelope now signs the full game context (game_id, round, ruleset, rng_seed, timestamp, players, state) — not just the player coins. Any tampering with envelope metadata invalidates the proof. v1 proofs are no longer accepted.',
  },
  {
    title: 'Production-quality polish',
    desc: 'Atomic writes everywhere (no half-written save files), structured logging for operators, --json output mode on diagnostic commands, and supply-chain attestation on released binaries.',
  },
  {
    title: 'Beginner-friendlier',
    desc: 'Install in 30 seconds with pipx install sovereignty-game, walk through the rules in 60 seconds with sov tutorial, and share scenario codes with friends.',
  },
];

// F-FE-001 nav: prepend a "What's new" entry so the section is reachable
// from the header on every page (the dispatch loop below renders it
// out-of-band so it isn't auto-included by config.sections.map).
const navItems = [
  { href: `${base}#whats-new`, label: "What's new" },
  ...config.sections.map(s => ({ href: `${base}#${s.id}`, label: s.title })),
];

// Exhaustiveness guard for section dispatch (Wave 5 / F-008).
//
// Two-layer guard:
//   1. Compile-time: the switch below narrows `s.kind` to `never` in the
//      default branch. If a new SectionConfig kind is added in site-config.ts
//      without a matching case, TypeScript fails the build with a type error
//      on `assertNever(kind)` ("argument is not assignable to never").
//   2. Run-time: any unknown kind that slips past the type checker (e.g. a
//      cast or a JSON-loaded section) logs a loud warning during `astro build`
//      so it cannot disappear silently.
//
// Whenever you add a new kind below, also add a matching renderer branch in
// the JSX dispatch further down in this file.
const KNOWN_SECTION_KINDS = ['features', 'data-table', 'code-cards', 'api'] as const;
type KnownSectionKind = typeof KNOWN_SECTION_KINDS[number];
function assertNever(_x: never, ctx: string): never {
  throw new Error(`Unhandled section kind in index.astro dispatch (${ctx})`);
}
for (const s of config.sections) {
  const kind = s.kind;
  switch (kind) {
    case 'features':
    case 'data-table':
    case 'code-cards':
    case 'api':
      break;
    default:
      // Compile-time check: this line errors if `kind` is not narrowed to
      // `never` (i.e. a new kind was added above without a case here).
      assertNever(kind, `id="${(s as { id?: string }).id ?? '<unknown>'}"`);
  }
  if (!KNOWN_SECTION_KINDS.includes(kind as KnownSectionKind)) {
    console.warn(`[index.astro] Unknown section kind "${kind}" (id="${s.id}"); section will render with empty body. Add a renderer branch or remove the section from site-config.ts.`);
  }
}
---

<BaseLayout
  title={config.title}
  description={config.description}
  logoBadge={config.logoBadge}
  brandName={config.brandName}
  repoUrl={config.repoUrl}
  npmUrl={config.npmUrl}
  footerText={config.footerText}
  nav={navItems}
>
  {/*
    HACK: root landing page can't inject OG/Twitter meta — site-theme
    BaseLayout has no head slot. Tracked upstream:
    https://github.com/mcp-tool-shop-org/site-theme/issues/5
    Restore <Fragment slot="head"> with og:* + twitter:* meta tags once
    site-theme 0.3.0 ships the slot. Handbook subroutes already carry
    the meta via Starlight's own head config.
  */}
  {/*
    F-FE-002 (Wave 9, a11y): skip-to-content link as the first focusable
    element of the page. Hidden until focused (sr-only-style off-screen
    positioning), then anchored top-left and high-contrast for keyboard
    users. Target is the `#main` div below — site-theme's BaseLayout wraps
    the slot in its own <main> with no id, and we can't edit that package
    here, so we add a tabbable `#main` landmark inside the slot instead.
  */}
  <a href="#main" class="skip-link">Skip to main content</a>

  <div id="main" tabindex="-1">
    <Hero {...config.hero} />

    {/*
      F-FE-001 (Wave 9): "What's new in v2.0.0" — release highlights.
      Positioned after Hero, before the existing Features section. Renders
      via the standard Section + FeatureGrid pair so styling stays
      consistent with the dispatched sections below; an extra paragraph
      below the grid carries the migration / release-notes links (the
      FeatureGrid `desc` field is plain text, so links live here instead).
    */}
    <Section id="whats-new" title="What's new in v2.0.0" subtitle="Three things to know about the v2 release.">
      <FeatureGrid features={whatsNewFeatures} />
      <p class="mt-6 text-sm text-dim">
        Migrating from v1? See the
        {' '}<a class="underline hover:text-heading" href="https://github.com/mcp-tool-shop-org/sovereignty/blob/main/docs/migration-v1-to-v2.md">migration guide</a>.
        {' '}Or read the
        {' '}<a class="underline hover:text-heading" href="https://github.com/mcp-tool-shop-org/sovereignty/blob/main/CHANGELOG.md">full release notes</a>.
      </p>
    </Section>

    {config.sections.map((s) => (
      <Section id={s.id} title={s.title} subtitle={s.subtitle}>
        {/*
          Renderer branches. Keep this list in sync with KNOWN_SECTION_KINDS in
          the frontmatter — the exhaustiveness loop above enforces that.
        */}
        {s.kind === 'features' && <FeatureGrid features={s.features} />}
        {s.kind === 'data-table' && <DataTable columns={s.columns} rows={s.rows} />}
        {s.kind === 'code-cards' && <CodeCardGrid cards={s.cards} />}
        {s.kind === 'api' && <ApiList apis={s.apis} />}
      </Section>
    ))}
  </div>
</BaseLayout>
